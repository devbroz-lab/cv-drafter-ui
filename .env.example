# Environments (see cv-drafter/markdowns/DEV_SETUP.md):
#   Local + dev Supabase: point API at localhost or Railway DEV API
#   Railway develop → dev UI service vars | Railway main → production vars
#
# Backend API (FastAPI sessions/pipeline)
VITE_API_BASE_URL=http://127.0.0.1:8000

# Backend auth API (served by cv-drafter)
VITE_AUTH_API_BASE_URL=http://127.0.0.1:8000/auth

# Google OAuth Web Client ID
VITE_GOOGLE_CLIENT_ID=your_google_web_client_id

# Microsoft Entra app (SPA) Client ID
VITE_MICROSOFT_CLIENT_ID=your_microsoft_client_id
